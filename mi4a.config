CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_mi-router-4a-gigabit=y

# 基础界面与语言
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# 开启网络加速 (MT7621 核心必备，可显著降低 CPU 占用并跑满千兆)
CONFIG_PACKAGE_luci-app-sfe=y
CONFIG_PACKAGE_luci-app-flowoffload=y

# ================= 极简模式：剔除默认臃肿插件 =================
# Lean 源码默认带了一些插件，16MB 闪存非常容易超载，必须精简掉！

# 取消文件共享和下载类插件 (16MB闪存也装不了什么东西，纯路由不需要这些)
# CONFIG_PACKAGE_luci-app-samba4 is not set
# CONFIG_PACKAGE_luci-app-vsftpd is not set
# CONFIG_PACKAGE_luci-app-xlnetacc is not set
# CONFIG_PACKAGE_luci-app-transmission is not set
# CONFIG_PACKAGE_luci-app-qbittorrent is not set

# 取消广告屏蔽和各种大型科学/代理插件 (体积太大，且非常消耗内存)
# CONFIG_PACKAGE_luci-app-adbyby-plus is not set
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-openclash is not set

# 取消 VPN 相关 (如果有需要可以单独保留一种，否则全砍)
# CONFIG_PACKAGE_luci-app-ipsec-vpnd is not set
# CONFIG_PACKAGE_luci-app-openvpn-server is not set
# CONFIG_PACKAGE_luci-app-wireguard is not set
# CONFIG_PACKAGE_luci-app-zerotier is not set

# 取消其他非必要插件
# CONFIG_PACKAGE_luci-app-unblockmusic is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_luci-app-qos is not set
# CONFIG_PACKAGE_luci-app-ramfree is not set
# CONFIG_PACKAGE_luci-app-ttyd is not set

# 取消非必要的后台调试工具
# CONFIG_PACKAGE_curl is not set
# CONFIG_PACKAGE_htop is not set
# CONFIG_PACKAGE_iperf3 is not set
# CONFIG_PACKAGE_nano is not set
# CONFIG_PACKAGE_screen is not set

# ================= 按需选择的插件 (默认均不启用) =================
# 如果你非常需要下面某项功能，可以去掉前面的 "# " (但要注意体积限制)

# 1. UPnP (如果打主机游戏或者用BT下载，建议开启，体积很小)
# CONFIG_PACKAGE_luci-app-upnp=y

# 2. DDNS (动态域名解析，如果有公网IP想从外网访问，可以开启)
# CONFIG_PACKAGE_luci-app-ddns=y

# 3. 极简的科学代理工具 (如果你必须在路由端使用代理，建议只用这一个最轻量的)
# CONFIG_PACKAGE_luci-app-shadowsocks-libev=y

# 4. 如果连 IPv6 都不需要，可以取消勾选，能再省出一点空间
# CONFIG_PACKAGE_ipv6helper is not set
